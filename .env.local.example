# ── Pusher (https://pusher.com — free Sandbox plan is enough) ──────────────────
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=ap2

# This one is public — safe to expose to the browser
NEXT_PUBLIC_PUSHER_KEY=your_key
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# ── Vercel KV (add via Vercel Dashboard → Storage → KV) ───────────────────────
# These are set automatically when you connect a KV store in Vercel.
# For local dev, copy them from the Vercel dashboard.
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token
